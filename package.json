{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "changelog:build": "node scripts/changelog.mjs --write",
    "changelog:check": "node scripts/changelog.mjs --check",
    "dev": "vite",
    "build": "npm run changelog:check && vue-tsc -b && vite build && node -e \"require('node:fs').copyFileSync('dist/index.html','dist/404.html')\"",
    "preview": "npm run build && wrangler dev",
    "test": "vitest run",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@fontsource-variable/noto-sans-sc": "^5.2.10",
    "@vueuse/core": "^14.2.1",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.30",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.6.4",
    "vuedraggable": "^4.1.0",
    "wavesurfer.js": "^7.12.5"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.31.0",
    "@tailwindcss/forms": "^0.5.11",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "autoprefixer": "^10.4.27",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.2.5",
    "wrangler": "^4.80.0"
  }
}
